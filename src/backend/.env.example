# Application
APP_NAME=Clap Cafe Ordering
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/clapcafe

# Redis
REDIS_URL=redis://localhost:6379/0

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PAYMENT_TIMEOUT_MINUTES=15

# CORS
CORS_ORIGINS=https://order.clapcafe.sg,http://localhost:5173

# API
API_V1_PREFIX=/v1
